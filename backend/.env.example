# Required — https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_api_key_here

DEBUG=false
FRONTEND_URL=http://localhost:3000
DB_PATH=averroes.db

# Optional LLM tuning (defaults match app/config.py)
# LLM_MODEL=deepseek-chat
# COACH_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com
# LLM_TIMEOUT=30
# LLM_MAX_RETRIES=2

# Rate limit (in-memory; see docs/ARCHITECTURE.md)
# RATE_LIMIT_REQUESTS=30
# RATE_LIMIT_WINDOW_SECONDS=60

# Uploads
# MAX_FILE_SIZE_MB=10

# ngrok: only if you use docker compose --profile tunnel
# https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=your_ngrok_authtoken_here
